---
import type { Translations } from '../../i18n/utils';
import skills from '../../content/skills.json';

interface Skill {
  name: string;
  level: number;
  cat: string;
}

interface Props {
  t: Translations['skills'];
}

const { t } = Astro.props;
const categories = [...new Set((skills as Skill[]).map(s => s.cat))];
---

<section id="skills-section" class="max-w-4xl mx-auto px-8 py-28">

  <p class="reveal font-mono text-xs tracking-widest uppercase text-accent mb-4">
    {t.eyebrow}
  </p>

  <h2 class="reveal font-serif font-light text-5xl leading-tight mb-12">
    {t.title}<br>
    <em class="italic text-accent">{t.titleEm}</em>
  </h2>

  <div class="reveal flex flex-wrap gap-2 mb-10">
    <button
      data-filter="all"
      class="filter-btn active font-mono text-xs px-4 py-1.5 rounded-full border border-accent bg-accent-soft text-accent transition-all duration-200"
    >
      {t.filterAll}
    </button>
    {categories.map((cat: string) => (
      <button
        data-filter={cat}
        class="filter-btn font-mono text-xs px-4 py-1.5 rounded-full border border-border text-text-muted hover:border-accent hover:text-accent transition-all duration-200"
      >
        {cat.toLowerCase()}
      </button>
    ))}
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {(skills as Skill[]).map((skill: Skill) => (
      <div
        class="skill-card bg-surface border border-border rounded-xl p-5 shadow-soft hover:-translate-y-0.5 hover:border-accent hover:shadow-lg transition-all duration-300 cursor-default"
        data-category={skill.cat}
      >
        <div class="flex justify-between items-baseline mb-3">
          <span class="text-sm font-medium text-text">{skill.name}</span>
          <span class="font-mono text-xs text-text-muted">{skill.level}%</span>
        </div>
        <div class="h-0.5 bg-bg2 rounded-full overflow-hidden">
          <div
            class="skill-bar h-full bg-accent rounded-full"
            style={`width: 0%; --target: ${skill.level}%`}
          ></div>
        </div>
        <p class="font-mono text-xs text-text-muted mt-2">{skill.cat}</p>
      </div>
    ))}
  </div>

</section>

<hr class="border-t border-border mx-8" />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('#skills-section .reveal').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, y: 20 },
      {
        opacity: 1, y: 0,
        duration: 0.7,
        delay: i * 0.1,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      }
    );
  });

  gsap.utils.toArray<HTMLElement>('.skill-card').forEach((card, i) => {
    gsap.fromTo(card,
      { opacity: 0, y: 24 },
      {
        opacity: 1, y: 0,
        duration: 0.5,
        delay: (i % 3) * 0.08,
        ease: 'power2.out',
        scrollTrigger: { trigger: card, start: 'top 88%', once: true },
      }
    );
  });

  gsap.utils.toArray<HTMLElement>('.skill-bar').forEach(bar => {
    const target = bar.style.getPropertyValue('--target');
    gsap.to(bar, {
      width: target,
      duration: 1,
      ease: 'power2.out',
      scrollTrigger: { trigger: bar, start: 'top 90%', once: true },
    });
  });

  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('.skill-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      filterBtns.forEach(b => {
        b.classList.remove('bg-accent-soft', 'text-accent', 'border-accent', 'active');
        b.classList.add('text-text-muted', 'border-border');
      });
      btn.classList.add('bg-accent-soft', 'text-accent', 'border-accent', 'active');
      btn.classList.remove('text-text-muted', 'border-border');
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        gsap.to(card, {
          opacity: match ? 1 : 0.2,
          scale:   match ? 1 : 0.97,
          duration: 0.3,
          ease: 'power2.out',
        });
      });
    });
  });
</script>