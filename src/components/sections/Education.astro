---
import timeline from '../../content/timeline.json';
---

<section id="education-section" class="max-w-4xl mx-auto px-8 py-28">

  <!-- Separateur -->
  <p class="reveal font-mono text-xs tracking-widest uppercase text-accent mb-4">
    03 — parcours
  </p>

  <!-- Titre -->
  <h2 class="reveal font-serif font-light text-5xl leading-tight mb-16">
    Formation &<br>
    <em class="italic text-accent">expériences</em>
  </h2>

  <!-- Timeline -->
  <div class="relative pl-6">

    <!-- Ligne verticale -->
    <div class="absolute left-0 top-2 bottom-2 w-px bg-border"></div>

    {timeline.map((item, i) => (
      <div
        class="timeline-item relative pb-12 last:pb-0"
        data-index={i}
      >
        <!-- Point sur la ligne -->
        <div class="absolute -left-6 top-1.5 w-3 h-3 rounded-full bg-accent border-2 border-bg shadow-sm"></div>

        <!-- Badge type -->
        <span class={`
          inline-block font-mono text-xs px-2.5 py-0.5 rounded-full mb-3
          ${item.type === 'experience'
            ? 'bg-accent-soft text-accent'
            : 'bg-bg2 text-text-muted border border-border'}
        `}>
          {item.type === 'experience' ? 'expérience' : 'formation'}
        </span>

        <p class="font-mono text-xs text-text-muted mb-1">{item.date}</p>
        <h3 class="text-lg font-medium text-text mb-0.5">{item.role}</h3>
        <p class="text-sm text-text-soft mb-3">{item.place}</p>
        <p class="text-sm leading-relaxed text-text-soft max-w-xl">{item.desc}</p>
      </div>
    ))}

  </div>

</section>

<hr class="border-t border-border mx-8" />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Reveals du titre
  gsap.utils.toArray<HTMLElement>('#education-section .reveal').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, y: 20 },
      {
        opacity: 1, y: 0,
        duration: 0.7,
        delay: i * 0.1,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      }
    );
  });

  // Items de la timeline en cascade depuis la gauche
  gsap.utils.toArray<HTMLElement>('.timeline-item').forEach((item, i) => {
    gsap.fromTo(item,
      { opacity: 0, x: -16 },
      {
        opacity: 1, x: 0,
        duration: 0.6,
        delay: i * 0.12,
        ease: 'power2.out',
        scrollTrigger: { trigger: item, start: 'top 88%', once: true },
      }
    );
  });
</script>