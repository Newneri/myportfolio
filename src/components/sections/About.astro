---
import type { Translations, InfoItem, InterestItem } from '../../i18n/utils';

interface Props {
  t: Translations['about'];
}

const { t } = Astro.props;
---

<section id="about-section" class="max-w-4xl mx-auto px-8 py-28">

  <p class="reveal font-mono text-xs tracking-widest uppercase text-accent mb-4">
    {t.eyebrow}
  </p>

  <h2 class="reveal font-serif font-light text-5xl leading-tight mb-12">
    {t.title}<br>
    <em class="italic text-accent">{t.titleEm}</em>
  </h2>

  <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

    <div class="flex flex-col gap-5">
      <p class="text-base leading-relaxed text-text-soft" set:html={t.p1} />
      <p class="text-base leading-relaxed text-text-soft" set:html={t.p2} />

      <div class="flex flex-col gap-2 pt-2">
        {t.info.map((item: InfoItem) => (
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-xs text-text-muted w-16 shrink-0">{item.label}</span>
            <span class="text-sm text-text-soft">{item.value}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-surface border border-border rounded-xl p-6 shadow-soft">
      <p class="font-mono text-xs tracking-widest uppercase text-text-muted mb-5">
        {t.interestsLabel}
      </p>
      <ul class="flex flex-col gap-4">
        {t.interests.map((item: InterestItem) => (
          <li class="flex items-start gap-4">
            <span class="text-2xl leading-none mt-0.5">{item.icon}</span>
            <div>
              <p class="text-sm font-medium text-text">{item.title}</p>
              <p class="text-xs text-text-muted mt-0.5">{item.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

  </div>

</section>

<hr class="border-t border-border mx-8" />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('#about-section .reveal').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, y: 20 },
      {
        opacity: 1, y: 0,
        duration: 0.7,
        delay: i * 0.1,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      }
    );
  });
</script>