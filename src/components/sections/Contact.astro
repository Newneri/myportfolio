<section id="contact-section" class="bg-bg2 border-t border-border px-8 py-28">
  <div class="max-w-2xl mx-auto text-center">
    <!-- Separateur -->
    <p
      class="reveal font-mono text-xs tracking-widest uppercase text-accent mb-4"
    >
      05 — contact
    </p>

    <!-- Titre -->
    <h2 class="reveal font-serif font-light text-5xl leading-tight mb-6">
      Travaillons<br />
      <em class="italic text-accent">ensemble</em>
    </h2>

    <!-- Sous-titre -->
    <p
      class="reveal text-base leading-relaxed text-text-soft max-w-md mx-auto mb-12"
    >
      Disponible du <strong class="text-text font-medium"
        >22 juin au 31 août</strong
      > pour un stage en développement web, logiciel ou data. Basé à Pau 64000.
    </p>

    <!-- CTA -->
    <div class="reveal flex flex-wrap justify-center gap-3 mb-16">
      <a
        href="mailto:hamid.akhatar0@gmail.com"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-white text-sm font-medium hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200"
      >
        <span>✉</span>
        m'écrire
      </a>
      <a
        href="/CV_stage_AkhatarAbdelhamid.pdf"
        target="_blank"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-surface border border-border text-text text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all duration-200"
      >
        <span>⬇</span>
        télécharger le CV
      </a>
      <a
        href="https://linkedin.com/in/abdelhamid-akhatar"
        target="_blank"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-surface border border-border text-text text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all duration-200"
      >
        <span>in</span>
        LinkedIn
      </a>
    </div>

    <!-- Séparateur -->
    <div class="w-px h-8 bg-border mx-auto mb-8"></div>

    <!-- Footer -->
    <div class="flex flex-col items-center gap-2">
      <p class="font-mono text-xs text-text-muted">
        Abdelhamid Akhatar — {new Date().getFullYear()}
      </p>
      <p class="font-mono text-xs text-text-muted opacity-60">
        Fait avec Astro, Tailwind & GSAP
      </p>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils
    .toArray<HTMLElement>("#contact-section .reveal")
    .forEach((el, i) => {
      gsap.fromTo(
        el,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          delay: i * 0.12,
          ease: "power2.out",
          scrollTrigger: { trigger: el, start: "top 88%", once: true },
        },
      );
    });
</script>
