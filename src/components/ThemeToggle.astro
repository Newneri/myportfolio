<button
  onclick="toggleTheme()"
  aria-label="Changer le thème"
  class="fixed top-5 right-6 z-50
    flex items-center gap-2
    bg-surface border border-border
    rounded-full px-3 py-1.5
    font-mono text-[0.68rem] text-text-muted
    shadow-soft cursor-pointer
    hover:text-text hover:border-accent
    transition-all duration-300"
>
  <!-- Point coloré indicateur -->
  <span
    class="w-1.5 h-1.5 rounded-full bg-accent transition-colors duration-300"
  ></span>

  <!-- Label : affiche le thème vers lequel on va basculer -->
  <span id="theme-label">dark</span>
</button>

<script is:inline>
  // Synchronise le label au chargement (cas où le thème a été restauré depuis localStorage)
  const label = document.getElementById("theme-label");
  if (label) {
    const current = document.documentElement.getAttribute("data-theme");
    label.textContent = current === "dark" ? "light" : "dark";
  }
</script>
