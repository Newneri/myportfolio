---
import type { Translations } from '../i18n/utils';

interface Props {
  t: Translations['terminal'];
}

const { t } = Astro.props;
---

<section
  id="terminal-section"
  class="min-h-screen flex items-center justify-center px-4 py-8"
>
  <div class="w-full max-w-2xl">

    <p class="font-mono text-xs tracking-widest uppercase text-text-muted mb-3">
      {t.label}
    </p>

    <div class="rounded-xl border border-border bg-bg overflow-hidden shadow-lg">

      <div class="flex items-center gap-2 px-4 py-3 bg-bg2 border-b border-border">
        <span class="w-2.5 h-2.5 rounded-full bg-[#FC6058]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#FEC02F]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#2ACA44]"></span>
        <span class="font-mono text-xs text-text-muted mx-auto -translate-x-4">
          zsh — ~
        </span>
      </div>

      <div
        id="terminal-body"
        class="px-8 py-7 font-mono text-sm leading-loose min-h-80 bg-bg"
      ></div>
    </div>

    <div id="scroll-hint" class="flex flex-col items-center gap-2 mt-8 opacity-0 transition-opacity duration-700">
      <span class="font-mono text-xs text-text-muted">{t.scrollHint}</span>
      <div class="w-px h-9 scroll-pulse bg-accent opacity-60"></div>
    </div>

  </div>
</section>

<script define:vars={{ lines: t.lines }}>
  const speedMap = { cmd: 60, output: 20, ok: 30 };

  function createRow(type) {
    const body = document.getElementById('terminal-body');
    if (!body) return null;

    if (type === 'spacer') {
      const spacer = document.createElement('div');
      spacer.className = 'h-2';
      body.appendChild(spacer);
      return null;
    }

    const row = document.createElement('div');
    row.className = 'flex items-start gap-2';

    if (type === 'cmd') {
      const prompt = document.createElement('span');
      prompt.className = 'text-accent select-none shrink-0';
      prompt.textContent = '→';
      row.appendChild(prompt);
    } else {
      const indent = document.createElement('span');
      indent.className = 'pl-5 shrink-0';
      row.appendChild(indent);
    }

    const target = document.createElement('span');
    target.className =
      type === 'ok'  ? 'text-green' :
      type === 'cmd' ? 'text-text'  : 'text-text-soft';
    row.appendChild(target);
    body.appendChild(row);
    return target;
  }

  function appendFinalCursor() {
    const body = document.getElementById('terminal-body');
    if (!body) return;
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
      <span class="text-accent select-none">→</span>
      <span class="inline-block w-0.5 h-4 bg-accent cursor-blink"></span>
    `;
    body.appendChild(row);
    setTimeout(() => {
      document.getElementById('scroll-hint')?.classList.add('opacity-100');
    }, 300);
    setTimeout(() => {
      const nav = document.getElementById('main-nav');
      nav?.classList.remove('opacity-0');
      nav?.classList.add('opacity-100');
    }, 700);
  }

  function runLine(index) {
    if (index >= lines.length) { appendFinalCursor(); return; }
    const line = lines[index];
    if (line.type === 'spacer') {
      createRow('spacer');
      setTimeout(() => runLine(index + 1), 180);
      return;
    }
    const target = createRow(line.type);
    if (!target || !line.text) { runLine(index + 1); return; }
    new Typed(target, {
      strings: [line.text],
      typeSpeed: speedMap[line.type] ?? 40,
      showCursor: false,
      onComplete: () => setTimeout(() => runLine(index + 1), 120),
    });
  }

  window.addEventListener('load', () => setTimeout(() => runLine(0), 400));
</script>